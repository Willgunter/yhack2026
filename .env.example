# ─── Praesidia .env.example ───────────────────────────────────────────────────
# Copy this to .env and fill in your values.
# Slack tokens are handled automatically via OAuth (Connect Slack button).
# You do NOT need SLACK_BOT_TOKEN or SLACK_APP_TOKEN in this file.
# ──────────────────────────────────────────────────────────────────────────────

# K2 Think V2 — AI compliance reasoning engine
# Get from: https://k2think.ai
K2_API_KEY=your_k2_api_key_here

# Resend — email alerts for violations
# Get from: https://resend.com (free tier works)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# Admin alert email — where violation emails are sent
ADMIN_EMAIL=your_email@example.com

# Auth0 — identity / role management
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret

# Supabase — policy storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Mem0 — user context memory
MEM0_API_KEY=your_mem0_api_key
MEM0_ORG_ID=your-org-default-org
MEM0_PROJECT_ID=default-project

# Tavus — video escalation (optional)
TAVUS_API_KEY=your_tavus_api_key

# Anthropic (optional — used for some features)
ANTHROPIC_API_KEY=your_anthropic_api_key
