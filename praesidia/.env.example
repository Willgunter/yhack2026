# Praesidia Environment Configuration
# Copy this file to .env and fill in your values

# K2 Think V2 — Legal reasoning via Cerebras Inference
# Free API key from https://cerebras.ai/k2think
CEREBRAS_API_KEY=
K2_MODEL=k2-think-v2

# Mem0 — Organizational memory API
# Get from https://app.mem0.ai
MEM0_API_KEY=

# Twilio — SMS escalation alerts
# Get from https://twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Slack — Bot integration
# Get from https://api.slack.com/apps
SLACK_BOT_TOKEN=        # xoxb- token
SLACK_SIGNING_SECRET=   # From Slack app settings
SLACK_APP_TOKEN=        # xapp- token for socket mode

# Person 3 analyze endpoint
PERSON3_ANALYZE_URL=http://localhost:5002/analyze

# Node.js K2 Brain server (Person 1's reasoning engine)
K2_BRAIN_URL=http://localhost:3000

# Praesidia settings
FLASK_PORT=5001
FLASK_DEBUG=false
PRAESIDIA_HOME=~/.praesidia
AUDIT_DB_PATH=~/.praesidia/audit.db
